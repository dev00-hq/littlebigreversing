def main
  options = parse_args(ARGV)

  if ARGV.empty?
    parse_args(['-h'])
  else
    url = ARGV[0]
  end

  puts "Got #{url}" unless ARGV.empty?
  target = parse_target_url(url)

  config = parse_config_file(options.config_file)
  api_key = config[:api_key]
  api_user = config[:api_user]
  username = options.username || config[:username]
  password = options.password || config[:password]
  if options.password_env
    env_password = ENV[options.password_env]
    raise "Environment variable #{options.password_env} is not set" unless env_password

    password = env_password
  end

  api_string = ""
  if api_key && api_user
    api_string = "?api_key=#{api_key}&api_user=#{api_user}"
    puts "Using API key auth for #{api_user}"
  elsif username && password
    login_session(target[:protocol], target[:host], username, password)
  elsif username || password
    raise 'Both username and password are required for session login'
  end

  @print_html= !options.markdown

  if @print_html
    puts "HTML!"
  else
    puts "NO HTMLE!"
  end

  if target[:type] == :topic
    url_map = {protocol: target[:protocol],
               host: target[:host],
               topic_id: target[:topic_id],
               post_num: "/1", # include slash e.g., "/5"
               api: api_string
              }

    print_topic(url_map)
  end

  if target[:type] == :category
    puts "Got a category: #{target[:cat]}"
    cat_map = {protocol: target[:protocol],
               host: target[:host],
               cat: target[:cat],
               api: api_string
              }
    puts "Her is: #{cat_map}"
    get_cat_topics(cat_map)
  end
end

def get_cat_topics(cat_map)
  cat_template = "%{protocol}://%{host}/c/%{cat}.json%{api}"
  url = cat_template % cat_map
  puts "Getting #{url}"

  web_page = http_get(url)
  data = JSON.parse(web_page)

  topic_list = data['topic_list']

  topics = topic_list['topics']

  cat_map[:post_num] = ""
  topics.each do |topic|
    puts "#{topic['id']}: #{topic['title']}"
    cat_map[:topic_id] = topic['id']
    print_topic(cat_map)
  end
end

main
