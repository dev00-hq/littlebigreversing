{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "checkpoint_id",
    "matches",
    "confidence",
    "summary",
    "observed",
    "negative_control_observations",
    "mismatches"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "game-drive-visual-classification-v1"
    },
    "checkpoint_id": {
      "type": "string",
      "minLength": 1
    },
    "matches": {
      "type": "boolean"
    },
    "confidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "observed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "twinsen_visible",
        "target_visible",
        "ui_state",
        "unsafe_pose_signs"
      ],
      "properties": {
        "twinsen_visible": {
          "type": "boolean"
        },
        "target_visible": {
          "type": "boolean"
        },
        "ui_state": {
          "enum": [
            "gameplay",
            "dialog",
            "menu",
            "unknown"
          ]
        },
        "unsafe_pose_signs": {
          "type": "boolean"
        }
      }
    },
    "mismatches": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "negative_control_observations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "matches",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "matches": {
            "type": "boolean"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
