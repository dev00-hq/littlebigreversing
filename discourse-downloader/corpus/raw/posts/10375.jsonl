{"id":269468,"name":null,"username":"ChaosFish","avatar_template":"/user_avatar/forum.magicball.net/chaosfish/{size}/2_2.png","created_at":"2006-11-12T05:52:03.000Z","cooked":"<p>LBA2 uses software emulation for 3D graphics, so I dont think enforcing anti-aliasing through the GPU driver will be useful It does work for Grim Fandango though.</p>","post_number":2,"post_type":1,"posts_count":13,"updated_at":"2024-10-25T17:50:21.992Z","reply_count":0,"reply_to_post_number":1,"quote_count":0,"incoming_link_count":0,"reads":1,"readers_count":0,"score":0.2,"yours":false,"topic_id":10375,"topic_slug":"anti-aliasing-in-lba2","display_username":null,"primary_group_name":null,"flair_name":null,"flair_url":null,"flair_bg_color":null,"flair_color":null,"flair_group_id":null,"badges_granted":[],"version":1,"can_edit":false,"can_delete":false,"can_recover":false,"can_see_hidden_post":false,"can_wiki":false,"user_title":null,"reply_to_user":{"id":2027,"username":"ContiX","name":null,"avatar_template":"/user_avatar/forum.magicball.net/contix/{size}/420_2.png"},"bookmarked":false,"raw":"LBA2 uses software emulation for 3D graphics, so I don't think enforcing anti-aliasing through the GPU driver will be useful... It does work for Grim Fandango though.","actions_summary":[{"id":2,"can_act":true},{"id":6,"can_act":true},{"id":3,"can_act":true},{"id":4,"can_act":true},{"id":8,"can_act":true},{"id":10,"can_act":true},{"id":7,"can_act":true}],"moderator":false,"admin":false,"staff":false,"group_moderator":true,"user_id":2,"hidden":false,"trust_level":1,"deleted_at":null,"user_deleted":false,"edit_reason":null,"can_view_edit_history":false,"wiki":false,"post_url":"/t/anti-aliasing-in-lba2/10375/2","reactions":[],"current_user_reaction":null,"reaction_users_count":0,"current_user_used_main_reaction":false,"can_accept_answer":false,"can_unaccept_answer":false,"accepted_answer":false,"topic_accepted_answer":null}
{"id":269503,"name":null,"username":"Battler","avatar_template":"/user_avatar/forum.magicball.net/battler/{size}/208_2.png","created_at":"2006-11-12T12:35:56.000Z","cooked":"<p>- ChaosFish: Anti-aliasing is not possible in either LBA games for the simply reason that both work in 256 colors, while anti-aliasing is usually for 16-bit and 32-bit colors. <img src=\"//forum.magicball.net/plugins/discourse-lba-emoji/images/takam/wink.png?v=12\" title=\":wink:\" class=\"emoji emoji-custom\" alt=\":wink:\" loading=\"lazy\" width=\"20\" height=\"20\"></p>","post_number":3,"post_type":1,"posts_count":13,"updated_at":"2024-10-25T17:50:23.332Z","reply_count":0,"reply_to_post_number":1,"quote_count":0,"incoming_link_count":0,"reads":1,"readers_count":0,"score":0.2,"yours":false,"topic_id":10375,"topic_slug":"anti-aliasing-in-lba2","display_username":null,"primary_group_name":null,"flair_name":null,"flair_url":null,"flair_bg_color":null,"flair_color":null,"flair_group_id":null,"badges_granted":[],"version":1,"can_edit":false,"can_delete":false,"can_recover":false,"can_see_hidden_post":false,"can_wiki":false,"user_title":null,"reply_to_user":{"id":2027,"username":"ContiX","name":null,"avatar_template":"/user_avatar/forum.magicball.net/contix/{size}/420_2.png"},"bookmarked":false,"raw":"\\- ChaosFish: Anti-aliasing is not possible in either LBA games for the simply reason that both work in 256 colors, while anti-aliasing is usually for 16-bit and 32-bit colors. ;)","actions_summary":[{"id":2,"can_act":true},{"id":6,"can_act":true},{"id":3,"can_act":true},{"id":4,"can_act":true},{"id":8,"can_act":true},{"id":10,"can_act":true},{"id":7,"can_act":true}],"moderator":false,"admin":false,"staff":false,"user_id":1016,"hidden":false,"trust_level":2,"deleted_at":null,"user_deleted":false,"edit_reason":null,"can_view_edit_history":false,"wiki":false,"post_url":"/t/anti-aliasing-in-lba2/10375/3","reactions":[],"current_user_reaction":null,"reaction_users_count":0,"current_user_used_main_react