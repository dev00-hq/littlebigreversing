{"id":218833,"name":null,"username":"xesf","avatar_template":"/user_avatar/forum.magicball.net/xesf/{size}/122_2.png","created_at":"2005-05-01T14:23:27.000Z","cooked":"<p>Congrats to all <img src=\"//forum.magicball.net/plugins/discourse-lba-emoji/images/takam/wink.png?v=12\" title=\":wink:\" class=\"emoji emoji-custom\" alt=\":wink:\" loading=\"lazy\" width=\"20\" height=\"20\"></p>","post_number":8,"post_type":1,"posts_count":16,"updated_at":"2024-10-25T17:19:41.111Z","reply_count":0,"reply_to_post_number":1,"quote_count":0,"incoming_link_count":1,"reads":0,"readers_count":0,"score":5.0,"yours":false,"topic_id":8410,"topic_slug":"lba2-is-now-in-full-hebrew","display_username":null,"primary_group_name":null,"flair_name":null,"flair_url":null,"flair_bg_color":null,"flair_color":null,"flair_group_id":null,"badges_granted":[],"version":1,"can_edit":false,"can_delete":false,"can_recover":false,"can_see_hidden_post":false,"can_wiki":false,"user_title":null,"reply_to_user":{"id":2,"username":"ChaosFish","name":null,"avatar_template":"/user_avatar/forum.magicball.net/chaosfish/{size}/2_2.png"},"bookmarked":false,"raw":"Congrats to all ;)","actions_summary":[{"id":2,"can_act":true},{"id":6,"can_act":true},{"id":3,"can_act":true},{"id":4,"can_act":true},{"id":8,"can_act":true},{"id":10,"can_act":true},{"id":7,"can_act":true}],"moderator":false,"admin":false,"staff":false,"group_moderator":true,"user_id":463,"hidden":false,"trust_level":2,"deleted_at":null,"user_deleted":false,"edit_reason":null,"can_view_edit_history":false,"wiki":false,"post_url":"/t/lba2-is-now-in-full-hebrew/8410/8","reactions":[],"current_user_reaction":null,"reaction_users_count":0,"current_user_used_main_reaction":false,"can_accept_answer":false,"can_unaccept_answer":false,"accepted_answer":false,"topic_accepted_answer":null}
{"id":218845,"name":null,"username":"ChaosFish","avatar_template":"/user_avatar/forum.magicball.net/chaosfish/{size}/2_2.png","created_at":"2005-05-01T17:11:52.000Z","cooked":"<aside class=\"quote no-group\" data-username=\"OBrasilo\">\n<div class=\"title\">\n<div class=\"quote-controls\"></div>\n OBrasilo:</div>\n<blockquote>\n<ul>\n<li>ChaosFish: In LBA 1, when you specify New Game, you see a text field and a character table below it, right? Well, in it, normally, there are English letter. But I found a way of modifying it.</li>\n</ul>\n</blockquote>\n</aside>\n<p>In LbaWin you only need to press RightAtl+RightShift and you write in Hebrew. (works on almost all Israeli computers)</p>\n<aside class=\"quote no-group\" data-username=\"morshem\">\n<div class=\"title\">\n<div class=\"quote-controls\"></div>\n<img loading=\"lazy\" alt=\"\" width=\"24\" height=\"24\" src=\"//forum.magicball.net/user_avatar/localhost/morshem/48/54_2.png\" class=\"avatar\"> morshem:</div>\n<blockquote>\n<p>I dreamt tonight that I got angry at Chaos because he didnt put my name in the credits in this thread.</p>\n</blockquote>\n</aside>\n<p>But I did!!!</p>","post_number":9,"post_type":1,"posts_count":16,"updated_at":"2024-10-25T17:19:41.532Z","reply_count":0,"reply_to_post_number":7,"quote_count":0,"incoming_link_count":1,"reads":0,"readers_count":0,"score":5.0,"yours":false,"topic_id":8410,"topic_slug":"lba2-is-now-in-full-hebrew","display_username":null,"primary_group_name":null,"flair_name":null,"flair_url":null,"flair_bg_color":null,"flair_color":null,"flair_group_id":null,"badges_granted":[],"version":1,"can_edit":false,"can_delete":false,"can_recover":false,"can_see_hidden_post":false,"can_wiki":false,"user_title":null,"reply_to_user":{"id":159,"username":"morshem","name":null,"avatar_template":"/user_avatar/forum.magicball.net/morshem/{size}/54_2.png"},"bookmarked":false,"raw":"\n[quote=\"OBrasilo\"]\n- ChaosFish: In LBA 1, when you specify New Game, you see a text field and a character table below it, right? Well, in it, normally, there are English letter. But I found a way of modifying it.\n[/quote]\nIn LbaWin you only need to press RightAtl+RightShift and you write in Hebrew. (works on almost all Israeli computers)\n[quote=\"morshem\"]\nI dreamt tonight that I got angry at Chaos because he didn't put my name in the credits in this thread.\n[/quote]\nBut I did!!!","actions_summary":[{"id":2,"can_act":true},{"id":6,"can_act":true},{"id":3,"can_act":true},{"id":4,"can_act":true},{"id":8,"can_act":true},{"id":10,"can_act":true},{"id":7,"can_act":true}],"moderator":false,"admin":false,"staff":false,"group_moderator":true,"user_id":2,"hidden":false,"trust_level":1,"deleted_at":null,"user_deleted":false,"edit_reason":null,"can_view_edit_history":false,"wiki":false,"post_url":"/t/lba2-is-now-in-full-hebrew/8410/9","reactions":[],"current_user_reaction":null,"reaction_users_count":0,"current_user_used_main_reaction":false,"can_accept_answer":false,"can_unaccept_answer":false,"accepted_answer":false,"topic_accepted_answer":null}
