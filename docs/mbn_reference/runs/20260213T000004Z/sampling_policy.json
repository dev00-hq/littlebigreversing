{
  "version": 1,
  "input_scope_default": "index_normalized",
  "chunk_size": 1,
  "limits": {
    "max_records": 1,
    "max_bytes": 1,
    "max_entities": 1
  },
  "source_rules": [
    {
      "patterns": [
        "corpus/index/*.jsonl",
        "corpus/normalized/*.jsonl"
      ],
      "mode": "jsonl_stream",
      "deferred": false,
      "max_records_per_chunk": 1
    },
    {
      "patterns": [
        "spec/*.md"
      ],
      "mode": "markdown_line_stream",
      "deferred": false,
      "max_records_per_chunk": 1
    },
    {
      "patterns": [
        "corpus/raw/topics/*.json",
        "corpus/raw/posts/*.jsonl"
      ],
      "mode": "windowed_topic_ids",
      "deferred": true,
      "window_size": 25
    }
  ]
}